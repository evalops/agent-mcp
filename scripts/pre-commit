#!/usr/bin/env bash

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

mapfile -t staged_go_files < <(git diff --cached --name-only --diff-filter=ACM -- "*.go")
if [ ${#staged_go_files[@]} -eq 0 ]; then
  exit 0
fi

STASHED=0
cleanup() {
  if [ "$STASHED" -eq 1 ]; then
    git stash pop -q >/dev/null 2>&1 || true
    STASHED=0
  fi
}
trap cleanup EXIT

if ! git diff --quiet -- . || [ -n "$(git ls-files --others --exclude-standard)" ]; then
  git stash push -q --keep-index --include-untracked -m "pre-commit-$(date +%s)"
  STASHED=1
fi

RESULT=0

echo "Running golangci-lint..."
golangci-lint run --new-from-rev=HEAD ./... || RESULT=$?

if [ $RESULT -eq 0 ]; then
  echo "Running go test..."
  go test -race -count=1 ./... || RESULT=$?
fi

exit $RESULT
