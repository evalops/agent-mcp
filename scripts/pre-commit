#!/usr/bin/env bash

set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

mapfile -t staged_go_files < <(git diff --cached --name-only --diff-filter=ACM -- '*.go')
if [ ${#staged_go_files[@]} -eq 0 ]; then
  exit 0
fi

STASHED=0
cleanup() {
  if [ "$STASHED" -eq 1 ]; then
    git stash pop -q >/dev/null 2>&1 || true
    STASHED=0
  fi
}
trap cleanup EXIT

if ! git diff --quiet -- . || [ -n "$(git ls-files --others --exclude-standard)" ]; then
  if git stash push -q --keep-index --include-untracked -m "pre-commit-$(date +%s)"; then
    STASHED=1
  fi
fi

echo "Running gofmt on staged files..."
gofmt -w "${staged_go_files[@]}"
git add -- "${staged_go_files[@]}"

RESULT=0
lint_args=(./...)

if git rev-parse --verify HEAD >/dev/null 2>&1; then
  lint_args=(--new-from-rev=HEAD ./...)
fi

if [ -f .golangci.yml ] || [ -f .golangci.yaml ] || [ -f .golangci.toml ] || [ -f .golangci.json ]; then
  echo "Running golangci-lint..."
  golangci-lint run "${lint_args[@]}" || RESULT=$?
else
  echo "Running go vet..."
  go vet ./... || RESULT=$?
fi

if [ $RESULT -eq 0 ]; then
  echo "Running go test..."
  go test -count=1 ./... || RESULT=$?
fi

exit $RESULT
